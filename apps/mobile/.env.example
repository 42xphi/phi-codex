# Recommended: Cloudflare Tunnel (works from any Wi‑Fi / LTE)
EXPO_PUBLIC_WS_URL=wss://your-codex.example

# Alternative: Your Mac Tailscale IP + server port
# EXPO_PUBLIC_WS_URL=ws://100.0.0.0:8787

# If you set server/.env (CODEX_REMOTE_TOKEN), the client token must match.
EXPO_PUBLIC_CODEX_TOKEN=changeme
