# If set, clients must connect with ?token=... matching this value
CODEX_REMOTE_TOKEN=changeme

HOST=0.0.0.0
PORT=8787

# Optional: serve the exported web UI from this folder (defaults to ../apps/web/out)
WEB_BUILD_DIR=

# Codex app-server (Codex.app)
CODEX_APP_SERVER_URL=ws://127.0.0.1:8788
CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex
CODEX_APP_SERVER_AUTOSTART=1

# Default workspace folder for new threads
CODEX_CWD=

# Optional: constrain file browsing/search to a single workspace root
CODEX_WORKSPACE_ROOT=

# Optional: where to store per-client conversation metadata
CODEX_DATA_DIR=

# Controls whether Codex asks for approval (matches Codex.app policies)
CODEX_APPROVAL_POLICY=untrusted

# Controls Codex sandbox policy (matches Codex.app policies)
CODEX_SANDBOX=danger-full-access

# Optional: expose your local Knowledge Base (KB) over HTTP endpoints:
# - GET  /kb/health
# - POST /kb/search   { q, limit }
# - POST /kb/doc      { id, maxChars }
#
# These endpoints are protected by CODEX_REMOTE_TOKEN (same token as WS).
KB_CWD=
KB_PY=kb.py
KB_CONFIG=kb_config.toml
KB_PYTHON=python3
KB_TIMEOUT_MS=30000
